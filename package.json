{
  "name": "musicplayer",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,svelte,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css,json}\"",
    "stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "quality": "npm run format:check && npm run lint && npm run stylelint && npm run rust:fmt:check && npm run rust:clippy && npm run check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^25.9.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^4.1.0",
    "stylelint": "^17.3.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": ["prettier --write", "eslint --fix"],
    "src/**/*.svelte": ["prettier --write", "eslint --fix", "stylelint --fix"],
    "src/**/*.css": ["prettier --write", "stylelint --fix"],
    "src-tauri/src/**/*.rs": ["rustfmt", "bash -c 'cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings'"]
  }
}
